---
import Layout from "../../layouts/Layout.astro";
import DirectorioInstitucionesComponent from "../../components/DirectorioInstituciones";
---

<Layout title="Directorio de Instituciones | Elige tu Futuro">
  <div
    class="bg-[#FAFAFA] min-h-screen pt-24 pb-32 overflow-hidden relative flex flex-col justify-start"
  >
    <div
      class="absolute top-0 right-0 w-[800px] h-[800px] bg-[#6544FF]/5 rounded-full blur-[150px] pointer-events-none mix-blend-multiply translate-x-1/3 -translate-y-1/4"
    >
    </div>

    <div
      class="absolute top-[30%] left-0 w-[500px] h-[500px] bg-[#0ea5e9]/5 rounded-full blur-[120px] pointer-events-none mix-blend-multiply -translate-x-1/2"
    >
    </div>

    <div class="container mx-auto px-6 lg:px-8 relative z-10 w-full">
      <DirectorioInstitucionesComponent client:load />
    </div>
  </div>
</Layout>
