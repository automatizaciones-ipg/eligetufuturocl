---
// src/pages/herramientas/test-vocacional.astro
import Layout from "../../layouts/Layout.astro";
import TestVocacionalComponent from "../../components/TestVocacional.tsx";
---

<Layout title="Test Vocacional Premium - Elige Tu Futuro">
  <div
    class="bg-[#FAFAFA] min-h-screen pt-24 pb-32 overflow-hidden relative flex flex-col justify-center"
  >
    {/* Fondos ambientales "Premium" (Orbes de luz súper tenues) */}
    <div
      class="absolute top-0 left-0 w-full h-[500px] bg-gradient-to-b from-[#6544FF]/5 to-transparent pointer-events-none"
    >
    </div>
    <div
      class="absolute top-1/4 right-[-10%] w-[500px] h-[500px] bg-[#6544FF]/10 rounded-full blur-[140px] pointer-events-none mix-blend-multiply"
    >
    </div>
    <div
      class="absolute bottom-1/4 left-[-10%] w-[600px] h-[600px] bg-[#947BFF]/10 rounded-full blur-[160px] pointer-events-none mix-blend-multiply"
    >
    </div>

    <div class="container mx-auto px-6 lg:px-8 relative z-10 w-full">
      {/* El Componente Inmersivo */}
      <TestVocacionalComponent client:load />
    </div>
  </div>
</Layout>
