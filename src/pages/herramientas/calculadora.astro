---
// src/pages/herramientas/calculadora.astro
import Layout from "../../layouts/Layout.astro";
import CalculadoraNem from "../../components/CalculadoraNem.tsx";
---

<Layout title="Calculadora de Puntaje PAES - Elige Tu Futuro">
  <div class="bg-[#fafafa] min-h-screen pt-24 pb-20">
    <div class="container mx-auto px-6 lg:px-8">
      {/* Encabezado de la página */}
      <div
        class="max-w-3xl mx-auto text-center mb-12 animate-in fade-in slide-in-from-bottom-4 duration-700"
      >
        <div
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#6544FF]/10 text-[#6544FF] font-semibold text-sm mb-6"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#6544FF] opacity-75"
            ></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-[#6544FF]"
            ></span>
          </span>
          Herramientas Oficiales
        </div>

        <h1
          class="font-black text-4xl md:text-6xl text-[#1A1528] tracking-tight leading-[1.1] mb-6"
        >
          Calculadora de <span class="italic text-[#6544FF]">NEM y Ranking</span
          >
        </h1>
        <p class="text-gray-500 text-lg md:text-xl font-medium">
          Descubre tu puntaje base para la PAES. Ingresa tus notas y te daremos
          tu puntaje al instante, sin recargar la página.
        </p>
      </div>

      {/* Aquí inyectamos el componente React interactivo */}
      <CalculadoraNem client:load />
    </div>
  </div>
</Layout>
