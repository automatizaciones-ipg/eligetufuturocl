---
import Layout from "../../layouts/Layout.astro";
import ContactoForm from "../../components/ContactoForm";
---

<Layout title="Contacto - EligeTuFuturo">
  <main
    class="min-h-screen bg-[#fafafa] relative overflow-hidden flex items-center justify-center py-20 px-4"
  >
    <!-- Sistema de luces de fondo premium (Glow subtle) -->
    <div
      class="absolute top-[-10%] left-[-10%] w-[50vw] h-[50vw] bg-gradient-to-br from-[#6544FF]/5 to-transparent rounded-full blur-[120px] pointer-events-none"
    >
    </div>
    <div
      class="absolute bottom-[-10%] right-[-10%] w-[40vw] h-[40vw] bg-gradient-to-tr from-gray-200/30 to-transparent rounded-full blur-[100px] pointer-events-none"
    >
    </div>

    <div
      class="w-full max-w-4xl mx-auto relative z-10 grid md:grid-cols-12 gap-12 items-center"
    >
      <!-- Columna Izquierda: Copys de soporte sutiles -->
      <div class="md:col-span-5 text-center md:text-left space-y-4">
        <span
          class="inline-block bg-white border border-gray-100 text-[#6544FF] font-black text-[10px] tracking-widest uppercase px-4 py-1.5 rounded-full shadow-sm"
        >
          Canal de Soporte
        </span>
        <h1
          class="font-black italic uppercase text-3xl md:text-4xl text-[#1A1528] tracking-tight leading-none"
        >
          ¿Tienes dudas? <br />
          <span class="text-[#6544FF]">Hablemos.</span>
        </h1>
        <p
          class="text-gray-400 text-sm font-medium leading-relaxed max-w-xs mx-auto md:mx-0"
        >
          Completa el formulario lateral si necesitas aclarar dudas operativas,
          metodológicas o comerciales. Respondemos en menos de 24 horas hábiles.
        </p>
      </div>

      <!-- Columna Derecha: Formulario React -->
      <div class="md:col-span-7">
        <ContactoForm client:load />
      </div>
    </div>
  </main>
</Layout>
