---
// src/pages/institucion/[id].astro
import type { GetStaticPaths } from "astro";
import { supabase } from "../../../lib/supabase";
import InstitucionDetalle from "../../components/InstitucionDetalle";
import Layout from "../../layouts/Layout.astro";

// ============================================================================
// 1. GENERACIÓN DE RUTAS (SOLO TRAEMOS LOS IDs - ¡VUELA!)
// ============================================================================
export const getStaticPaths = (async () => {
  let allCodes: any[] = [];
  let hasMore = true;
  let page = 0;
  const limit = 1000;

  // Solo pedimos la columna "codigo_institucion". Esto hace que la consulta sea
  // super ligera, evitando cuellos de botella.
  while (hasMore) {
    const { data, error } = await supabase
      .from("instituciones")
      .select("codigo_institucion")
      .range(page * limit, (page + 1) * limit - 1);

    if (error || !data || data.length === 0) {
      hasMore = false;
    } else {
      allCodes = [...allCodes, ...data];
      page++;
    }
  }

  // Retornamos SOLO el param de la URL, sin pasar data pesada por props
  return allCodes.map((inst) => ({
    params: { id: inst.codigo_institucion.toString() },
  }));
}) satisfies GetStaticPaths;

// ============================================================================
// 2. OBTENEMOS EL ID DE LA URL Y BUSCAMOS SU DATA ESPECÍFICA
// ============================================================================
const { id } = Astro.params;

// Traemos los detalles ÚNICAMENTE de la institución a la que el usuario hizo clic
const { data: institucion, error } = await supabase
  .from("instituciones")
  .select("*")
  .eq("codigo_institucion", id)
  .single(); // .single() hace que traiga un objeto exacto

// Si la institución no existe o escriben un ID falso, redireccionamos a 404
if (error || !institucion) {
  return Astro.redirect("/404");
}

const title = `${institucion.nombre} | Directorio de Educación Superior`;
---

{
  /* Eliminamos el prop 'description' para evitar el error de TypeScript y mantenerlo igual que en Carreras */
}
<Layout title={title}>
  <main class="min-h-screen bg-[#F4F5F9]">
    <InstitucionDetalle institucion={institucion} client:load />
  </main>
</Layout>

<style>
  main {
    contain: content;
  }
</style>
