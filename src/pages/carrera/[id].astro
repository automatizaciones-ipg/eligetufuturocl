---
// src/pages/carrera/[id].astro
import type { GetStaticPaths } from "astro";
import { supabase } from "../../../lib/supabase";
import CarreraDetalle from "../../components/CarreraDetalle";
import Layout from "../../layouts/Layout.astro";

// ============================================================================
// 1. GENERACIÓN DE RUTAS (SOLO TRAEMOS LOS IDs - ¡VUELA!)
// ============================================================================
export const getStaticPaths = (async () => {
  let allCodes: any[] = [];
  let hasMore = true;
  let page = 0;
  const limit = 1000;

  // Solo pedimos la columna "codigo_carrera". Esto hace que la consulta sea
  // 100 veces más ligera, evitando que tu servidor colapse.
  while (hasMore) {
    const { data, error } = await supabase
      .from("carreras")
      .select("codigo_carrera")
      .range(page * limit, (page + 1) * limit - 1);

    if (error || !data || data.length === 0) {
      hasMore = false;
    } else {
      allCodes = [...allCodes, ...data];
      page++;
    }
  }

  // Retornamos SOLO el param de la URL, sin pasar data pesada por props
  return allCodes.map((carrera) => ({
    params: { id: carrera.codigo_carrera.toString() },
  }));
}) satisfies GetStaticPaths;

// ============================================================================
// 2. OBTENEMOS EL ID DE LA URL Y BUSCAMOS SU DATA ESPECÍFICA
// ============================================================================
const { id } = Astro.params;

// Traemos los detalles ÚNICAMENTE de la carrera a la que el usuario hizo clic
const { data: carrera, error } = await supabase
  .from("carreras")
  .select(
    `
    *,
    instituciones (nombre, tipo)
  `,
  )
  .eq("codigo_carrera", id)
  .single(); // .single() hace que traiga un objeto, no un array

// Si por alguna razón la carrera no existe, ahí sí tiramos un 404 real
if (error || !carrera) {
  return Astro.redirect("/404");
}

const title = `${carrera.nombre_carrera} - ${carrera.instituciones?.nombre} | Elige Tu Futuro`;
---

<Layout title={title}>
  <main class="min-h-screen bg-[#F4F5F9]">
    <CarreraDetalle carrera={carrera} client:load />
  </main>
</Layout>

<style>
  main {
    contain: content;
  }
</style>
