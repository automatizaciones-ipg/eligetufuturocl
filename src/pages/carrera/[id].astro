---
// src/pages/carrera/[id].astro
import type { GetStaticPaths } from "astro";
import { supabase } from "../../../lib/supabase";
import CarreraDetalle from "../../components/CarreraDetalle";
import Layout from "../../layouts/Layout.astro";

// ============================================================================
// 1. INTERFACES ESTRICTAS
// ============================================================================
export interface CarreraDB {
  codigo_carrera: number;
  nombre_carrera: string;
  nivel_carrera: string;
  duracion_semestres: number;
  arancel_anual: number;
  instituciones: {
    nombre: string;
    tipo: string;
  };
  // Agrega aquí otros campos que uses en CarreraDetalle
}

interface Props {
  carrera: CarreraDB;
}

// ============================================================================
// 2. GENERACIÓN DE RUTAS (SSG OPTIMIZADO)
// ============================================================================
export const getStaticPaths = (async () => {
  let allCarreras: CarreraDB[] = [];
  let hasMore = true;
  let page = 0;
  const limit = 1000;

  while (hasMore) {
    const { data, error } = await supabase
      .from("carreras")
      .select(
        `
        *,
        instituciones (nombre, tipo)
      `,
      )
      .range(page * limit, (page + 1) * limit - 1);

    if (error) {
      console.error("Error en Supabase:", error.message);
      break;
    }

    if (data && data.length > 0) {
      allCarreras = [...allCarreras, ...(data as CarreraDB[])];
      page++;
    } else {
      hasMore = false;
    }
  }

  return allCarreras.map((carrera) => ({
    params: { id: carrera.codigo_carrera.toString() },
    props: { carrera },
  }));
}) satisfies GetStaticPaths;

const { carrera } = Astro.props as Props;
const title = `${carrera.nombre_carrera} - ${carrera.instituciones?.nombre} | Elige Tu Futuro`;
---

<Layout title={title}>
  <main class="min-h-screen bg-[#F4F5F9]">
    <CarreraDetalle carrera={carrera} client:load />
  </main>
</Layout>

<style>
  main {
    /* Evita el salto visual (CLS) al cargar */
    contain: content;
  }
</style>
