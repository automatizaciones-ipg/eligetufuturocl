---
// src/pages/carrera/[id].astro
import type { GetStaticPaths } from "astro";
import { supabase } from "../../../lib/supabase";
import CarreraDetalle from "../../components/CarreraDetalle";
import Layout from "../../layouts/Layout.astro";

export const getStaticPaths = (async () => {
  let allCodes: any[] = [];
  let hasMore = true;
  let page = 0;
  const limit = 1000;

  while (hasMore) {
    const { data, error } = await supabase
      .from("carreras")
      .select("codigo_carrera")
      .range(page * limit, (page + 1) * limit - 1);

    if (error || !data || data.length === 0) {
      hasMore = false;
    } else {
      allCodes = [...allCodes, ...data];
      page++;
    }
  }

  return allCodes.map((carrera) => ({
    params: { id: carrera.codigo_carrera.toString() },
  }));
}) satisfies GetStaticPaths;

const { id } = Astro.params;

const { data: carrera, error } = await supabase
  .from("carreras")
  .select(
    `
    *,
    instituciones (
      nombre, 
      tipo,
      logo_url
    )
  `,
  )
  .eq("codigo_carrera", id)
  .single();

if (error || !carrera) {
  return Astro.redirect("/404");
}

const title = `${carrera.nombre_carrera} - ${carrera.instituciones?.nombre} | Elige Tu Futuro`;
---

<Layout title={title}>
  <main class="min-h-screen bg-[#F4F5F9]">
    <CarreraDetalle carrera={carrera} client:load />
  </main>
</Layout>

<style>
  main {
    contain: content;
  }
</style>
