# ─── Supabase ───────────────────────────────────────────────
PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
PUBLIC_SUPABASE_ANON_KEY=tu_anon_key
# Recomendado en producción (evita bloqueos RLS en APIs):
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# ─── Resend (correos transaccionales) ───────────────────────
# Obtén tu API key en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Remitente verificado en Resend (debe ser de tu dominio):
# Ejemplo: "EligeTuFuturo <contacto@eligetufuturo.cl>"
RESEND_FROM_EMAIL=EligeTuFuturo <contacto@eligetufuturo.cl>

# Correo interno donde llegan los leads y contactos:
RESEND_TO_EMAIL=contacto@eligetufuturo.cl

# ─── Sitio ──────────────────────────────────────────────────
PUBLIC_SITE_URL=https://eligetufuturo.cl

# ─── Marketing (opcional, protege /api/marketing/enviar) ───
MARKETING_API_SECRET=tu_secreto_largo_y_aleatorio
